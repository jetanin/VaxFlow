# VacFlow — ตัวอย่าง environment variables (คัดลอกเป็น .env แล้วแก้ค่า)
# production: ตั้งค่าทุกตัวที่เป็น secret ใหม่ทั้งหมด อย่าใช้ค่า default ในโค้ด

# ── Kaggle (ดาวน์โหลด dataset ใน notebook 00) ──
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# ── Postgres (webapp DB) ──
POSTGRES_USER=vacflow
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=vacflow

# ── Backend ──
JWT_SECRET=change-me-very-long-random        # บังคับใน production (NODE_ENV=production แล้วไม่ตั้ง = start ไม่ขึ้น)
RESEED_TOKEN=change-me-reseed-token          # service-to-service สำหรับ retrainer -> /api/reseed
DEFAULT_PASSWORD=vacflow123                  # รหัสตั้งต้นของ user ที่ seed (เปลี่ยนหลัง deploy)
IP_GEO=maxmind                               # maxmind (offline) | ipapi (online)

# ── Mock HOSxP (HIS connector, read-only) ──
HIS_DB_HOST=mock-his
HIS_DB_USER=vacflow_ro
HIS_DB_PASS=change-me-his-ro
HIS_DB_NAME=mock_hosxp

# ── vaccine-engine ──
ENGINE_URL=http://vaccine-engine:8500

# ── pipeline / retrainer ──
VACFLOW_NOW=2026-06-26T08:00:00+07:00        # time anchor เดียว (ตั้งวันจริงได้)
VACFLOW_TRAIN=1                              # 1 = รัน ML benchmark (GPU) ใน pipeline
VACFLOW_MODELS=XGBoost                       # โมเดลที่ ML benchmark เทรน (ว่าง=ครบ)
VACFLOW_N_TRIALS=40                          # จำนวน Optuna trial
RUN_AT=01:00                                 # เวลาเทรนรายวัน (retrainer)
